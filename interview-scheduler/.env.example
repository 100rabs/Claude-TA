# Copy to .env and fill in real values when you're ready to wire real providers.
# Leave blank to use the built-in mocks.

# Integration toggles
CALENDAR_PROVIDER=mock        # mock | google | outlook
EMAIL_PROVIDER=mock           # mock | sendgrid | resend
BIAS_DETECTOR=regex           # regex | claude

# Real provider credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SENDGRID_API_KEY=
ANTHROPIC_API_KEY=

# Auth
SECRET_KEY=change-me-in-production
